{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git status)"
    ]
  },
  "model": "claude-opus-4-8",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "theme": "dark-ansi",
  "editorMode": "vim"
}
